@page "/tickets/overdue"
@using FactoryFlow.Modules.Tickets.Application.Queries.GetOverdueTickets
@using FactoryFlow.Modules.Tickets.Application.Queries.GetTicketCreationLookups
@using FactoryFlow.Modules.Tickets.Application.Queries.GetTicketStatusLookups
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Supervisor,Admin")]
@rendermode InteractiveServer
@inject GetOverdueTicketsQueryHandler Handler
@inject GetTicketStatusLookupsQueryHandler StatusLookupsHandler
@inject GetTicketCreationLookupsQueryHandler CreationLookupsHandler
@inject NavigationManager Navigation

<PageTitle>Überfällige Tickets – FactoryFlow</PageTitle>

<div class="container-fluid">
    <a href="tickets" class="btn btn-outline-secondary btn-sm mb-3">
        <i class="bi bi-arrow-left me-1"></i>Zurück zur Liste
    </a>

    <h2 class="mb-4">Überfällige Tickets</h2>

    <div class="card mb-3">
        <div class="card-body py-2">
            <div class="row g-2 align-items-end">
                <div class="col-auto">
                    <label class="form-label mb-0 small">Priorität</label>
                    <select class="form-select form-select-sm" @onchange="HandlePriorityFilterChanged">
                        <option value="">Alle</option>
                        @foreach (var p in _priorityLookups)
                        {
                            <option value="@p.Id" selected="@(_filterPriorityId == p.Id)">@p.Name</option>
                        }
                    </select>
                </div>
                <div class="col-auto">
                    <label class="form-label mb-0 small">Abteilung</label>
                    <select class="form-select form-select-sm" @onchange="HandleDepartmentFilterChanged">
                        <option value="">Alle</option>
                        @foreach (var d in _departmentLookups)
                        {
                            <option value="@d.Id" selected="@(_filterDepartmentId == d.Id)">@d.Name</option>
                        }
                    </select>
                </div>
                <div class="col-auto">
                    <label class="form-label mb-0 small">Status</label>
                    <select class="form-select form-select-sm" @onchange="HandleStatusFilterChanged">
                        <option value="">Alle</option>
                        @foreach (var s in _statusLookups)
                        {
                            <option value="@s.Id" selected="@(_filterStatusId == s.Id)">@s.Name</option>
                        }
                    </select>
                </div>
            </div>
        </div>
    </div>

    @if (_loading)
    {
        <div class="d-flex align-items-center gap-2 my-4">
            <div class="spinner-border spinner-border-sm" role="status"></div>
            <span>Überfällige Tickets werden geladen...</span>
        </div>
    }
    else if (_loadError is not null)
    {
        <div class="alert alert-danger">@_loadError</div>
    }
    else if (_result is null || _result.Items.Count == 0)
    {
        <div class="alert alert-success">
            Keine überfälligen Tickets vorhanden.
        </div>
    }
    else
    {
        <p class="text-muted mb-3">@_result.TotalCount überfällige(s) Ticket(s)</p>

        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>Ticket-Nr.</th>
                        <th>Titel</th>
                        <th>Priorität</th>
                        <th>Status</th>
                        <th>Abteilung</th>
                        <th>Standort</th>
                        <th>Maschine / Arbeitsplatz</th>
                        <th>Fällig seit</th>
                        <th>Überfällig um</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ticket in _result.Items)
                    {
                        <tr role="button" style="cursor: pointer;" @onclick="() => NavigateToDetail(ticket.Id)">
                            <td class="text-nowrap">@ticket.TicketNumber</td>
                            <td>@ticket.Title</td>
                            <td>@ticket.PriorityName</td>
                            <td>@ticket.StatusName</td>
                            <td>@(ticket.DepartmentName ?? "—")</td>
                            <td>@(ticket.SiteName ?? "—")</td>
                            <td>@(ticket.MachineOrWorkstation ?? "—")</td>
                            <td class="text-nowrap">@ticket.DueAtUtc.ToString("dd.MM.yyyy HH:mm")</td>
                            <td class="text-nowrap text-danger fw-semibold">@FormatOverdueBy(ticket.OverdueBy)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private OverdueTicketsResultDto? _result;
    private bool _loading = true;
    private string? _loadError;

    private IReadOnlyList<LookupItemDto> _statusLookups = [];
    private IReadOnlyList<LookupItemDto> _priorityLookups = [];
    private IReadOnlyList<LookupItemDto> _departmentLookups = [];

    private Guid? _filterPriorityId;
    private Guid? _filterDepartmentId;
    private Guid? _filterStatusId;

    private void NavigateToDetail(Guid ticketId) =>
        Navigation.NavigateTo($"tickets/{ticketId}");

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _statusLookups = await StatusLookupsHandler.HandleAsync();
            var creationLookups = await CreationLookupsHandler.HandleAsync();
            _priorityLookups = creationLookups.Priorities;
            _departmentLookups = creationLookups.Departments;

            await LoadTicketsAsync();
        }
        catch (Exception ex)
        {
            _loadError = $"Überfällige Tickets konnten nicht geladen werden: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadTicketsAsync()
    {
        var query = new GetOverdueTicketsQuery(_filterPriorityId, _filterDepartmentId, _filterStatusId);
        _result = await Handler.HandleAsync(query);
    }

    private async Task HandlePriorityFilterChanged(ChangeEventArgs e)
    {
        _filterPriorityId = Guid.TryParse(e.Value?.ToString(), out var id) ? id : null;
        await LoadTicketsAsync();
    }

    private async Task HandleDepartmentFilterChanged(ChangeEventArgs e)
    {
        _filterDepartmentId = Guid.TryParse(e.Value?.ToString(), out var id) ? id : null;
        await LoadTicketsAsync();
    }

    private async Task HandleStatusFilterChanged(ChangeEventArgs e)
    {
        _filterStatusId = Guid.TryParse(e.Value?.ToString(), out var id) ? id : null;
        await LoadTicketsAsync();
    }

    private static string FormatOverdueBy(TimeSpan overdueBy)
    {
        if (overdueBy.TotalDays >= 1)
        {
            var days = (int)overdueBy.TotalDays;
            var hours = overdueBy.Hours;
            return hours > 0 ? $"{days} T {hours} Std." : $"{days} T";
        }

        if (overdueBy.TotalHours >= 1)
        {
            var hours = (int)overdueBy.TotalHours;
            var minutes = overdueBy.Minutes;
            return minutes > 0 ? $"{hours} Std. {minutes} Min." : $"{hours} Std.";
        }

        return $"{(int)overdueBy.TotalMinutes} Min.";
    }
}
