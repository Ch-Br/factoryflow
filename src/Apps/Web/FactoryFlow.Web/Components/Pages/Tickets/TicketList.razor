@page "/tickets"
@using FactoryFlow.Modules.Tickets.Application.Queries.GetTicketCreationLookups
@using FactoryFlow.Modules.Tickets.Application.Queries.GetTicketsList
@using FactoryFlow.Modules.Tickets.Application.Queries.GetTicketStatusLookups
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@rendermode InteractiveServer
@inject GetTicketsListQueryHandler Handler
@inject GetTicketStatusLookupsQueryHandler StatusLookupsHandler
@inject GetTicketCreationLookupsQueryHandler CreationLookupsHandler
@inject NavigationManager Navigation

<PageTitle>Tickets – FactoryFlow</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">Tickets</h2>
        <a href="tickets/create" class="btn btn-primary">Neues Ticket</a>
    </div>

    <div class="card mb-3">
        <div class="card-body py-2">
            <div class="row g-2 align-items-end">
                <div class="col-auto">
                    <label class="form-label mb-0 small">Status</label>
                    <select class="form-select form-select-sm" @onchange="HandleStatusFilterChanged">
                        <option value="">Alle</option>
                        @foreach (var s in _statusLookups)
                        {
                            <option value="@s.Id" selected="@(_filterStatusId == s.Id)">@s.Name</option>
                        }
                    </select>
                </div>
                <div class="col-auto">
                    <label class="form-label mb-0 small">Priorität</label>
                    <select class="form-select form-select-sm" @onchange="HandlePriorityFilterChanged">
                        <option value="">Alle</option>
                        @foreach (var p in _priorityLookups)
                        {
                            <option value="@p.Id" selected="@(_filterPriorityId == p.Id)">@p.Name</option>
                        }
                    </select>
                </div>
                <div class="col-auto">
                    <label class="form-label mb-0 small">Abteilung</label>
                    <select class="form-select form-select-sm" @onchange="HandleDepartmentFilterChanged">
                        <option value="">Alle</option>
                        @foreach (var d in _departmentLookups)
                        {
                            <option value="@d.Id" selected="@(_filterDepartmentId == d.Id)">@d.Name</option>
                        }
                    </select>
                </div>
                <div class="col-auto d-flex align-items-center" style="padding-bottom: 2px;">
                    <div class="form-check form-switch mb-0">
                        <input class="form-check-input" type="checkbox" id="onlyOpenSwitch"
                               checked="@_filterOnlyOpen" @onchange="HandleOnlyOpenChanged" />
                        <label class="form-check-label small" for="onlyOpenSwitch">Nur offene Tickets</label>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (_loading)
    {
        <div class="d-flex align-items-center gap-2 my-4">
            <div class="spinner-border spinner-border-sm" role="status"></div>
            <span>Tickets werden geladen...</span>
        </div>
    }
    else if (_loadError is not null)
    {
        <div class="alert alert-danger">@_loadError</div>
    }
    else if (_result is null || _result.Items.Count == 0)
    {
        <div class="alert alert-info">
            Keine Tickets vorhanden.
            <a href="tickets/create" class="alert-link">Erstes Ticket erstellen</a>
        </div>
    }
    else
    {
        <p class="text-muted mb-3">@_result.TotalCount Ticket(s)</p>

        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>Ticket-Nr.</th>
                        <th>Titel</th>
                        <th>Typ</th>
                        <th>Priorität</th>
                        <th>Status</th>
                        <th>Abteilung</th>
                        <th>Standort</th>
                        <th>Maschine / Arbeitsplatz</th>
                        <th>Fällig</th>
                        <th>Erstellt am</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ticket in _result.Items)
                    {
                        <tr role="button" style="cursor: pointer;" @onclick="() => NavigateToDetail(ticket.Id)">
                            <td class="text-nowrap">@ticket.TicketNumber</td>
                            <td>@ticket.Title</td>
                            <td>@ticket.TicketTypeName</td>
                            <td>@ticket.PriorityName</td>
                            <td>@ticket.StatusName</td>
                            <td>@(ticket.DepartmentName ?? "—")</td>
                            <td>@(ticket.SiteName ?? "—")</td>
                            <td>@(ticket.MachineOrWorkstation ?? "—")</td>
                            <td class="text-nowrap">
                                @if (ticket.DueAtUtc.HasValue)
                                {
                                    <span>@ticket.DueAtUtc.Value.ToString("dd.MM.yyyy HH:mm")</span>
                                    @switch (ticket.DueState)
                                    {
                                        case "Overdue":
                                            <span class="badge bg-danger ms-1">Überfällig</span>
                                            break;
                                        case "DueSoon":
                                            <span class="badge bg-warning text-dark ms-1">Bald fällig</span>
                                            break;
                                        case "OnTrack":
                                            <span class="badge bg-success ms-1">Im Plan</span>
                                            break;
                                    }
                                }
                                else
                                {
                                    <span>—</span>
                                }
                            </td>
                            <td class="text-nowrap">@ticket.CreatedAtUtc.ToString("dd.MM.yyyy HH:mm")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private TicketListResultDto? _result;
    private bool _loading = true;
    private string? _loadError;

    private IReadOnlyList<LookupItemDto> _statusLookups = [];
    private IReadOnlyList<LookupItemDto> _priorityLookups = [];
    private IReadOnlyList<LookupItemDto> _departmentLookups = [];

    private Guid? _filterStatusId;
    private Guid? _filterPriorityId;
    private Guid? _filterDepartmentId;
    private bool _filterOnlyOpen;

    private void NavigateToDetail(Guid ticketId) =>
        Navigation.NavigateTo($"tickets/{ticketId}");

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _statusLookups = await StatusLookupsHandler.HandleAsync();
            var creationLookups = await CreationLookupsHandler.HandleAsync();
            _priorityLookups = creationLookups.Priorities;
            _departmentLookups = creationLookups.Departments;

            await LoadTicketsAsync();
        }
        catch (Exception ex)
        {
            _loadError = $"Tickets konnten nicht geladen werden: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadTicketsAsync()
    {
        var query = new GetTicketsListQuery(_filterStatusId, _filterPriorityId, _filterDepartmentId, _filterOnlyOpen);
        _result = await Handler.HandleAsync(query);
    }

    private async Task HandleStatusFilterChanged(ChangeEventArgs e)
    {
        _filterStatusId = Guid.TryParse(e.Value?.ToString(), out var id) ? id : null;
        await LoadTicketsAsync();
    }

    private async Task HandlePriorityFilterChanged(ChangeEventArgs e)
    {
        _filterPriorityId = Guid.TryParse(e.Value?.ToString(), out var id) ? id : null;
        await LoadTicketsAsync();
    }

    private async Task HandleDepartmentFilterChanged(ChangeEventArgs e)
    {
        _filterDepartmentId = Guid.TryParse(e.Value?.ToString(), out var id) ? id : null;
        await LoadTicketsAsync();
    }

    private async Task HandleOnlyOpenChanged(ChangeEventArgs e)
    {
        _filterOnlyOpen = e.Value is bool b && b;
        await LoadTicketsAsync();
    }
}
